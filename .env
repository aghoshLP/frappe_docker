# --- Core App Version ---
ERPNEXT_VERSION=v16.10.1

# --- Database ---
DB_PASSWORD=StrongDBPass123

# --- Site Configuration ---
FRAPPE_SITE_NAME_HEADER=your-app-name.onrender.com

# --- Ports ---
HTTP_PUBLISH_PORT=8080

# --- Disable HTTPS for now (Render handles it) ---
LETSENCRYPT_EMAIL=

# --- Keep empty unless using external services ---
DB_HOST=
DB_PORT=
REDIS_CACHE=
REDIS_QUEUE=

# --- Proxy / Network (safe defaults) ---
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off

# --- Performance / Upload ---
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# --- Routing (IMPORTANT) ---
SITES_RULE=Host(`your-app-name.onrender.com`)
NGINX_PROXY_HOSTS=your-app-name.onrender.com
